# ============================================
# DigiGuard - Environment Variables
# ============================================
# 
# HOW TO USE:
# 1. Copy this file and rename it to ".env"
#    (remove the .example part)
#
# 2. Go to https://supabase.com
#    → Create a free account
#    → Create a new project called "digiguard"
#    → Choose region: Singapore (or nearest)
#
# 3. In your Supabase project, go to:
#    Settings → API
#    Copy the values below:
#
# ============================================

# Your Supabase Project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://qvyjtegkweuqpcmptswm.supabase.co

# Your Supabase Anon (Public) Key
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx...
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF2eWp0ZWdrd2V1cXBjbXB0c3dtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2Njc1OTgsImV4cCI6MjA4OTI0MzU5OH0.pzu31Jo4H3O0ph4a3AbyZ-g93zj4ZGoevbWw7-Ycc5I

